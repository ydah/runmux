{
  "version": 1,
  "default_profile": "dev",
  "profiles": [
    {
      "name": "dev",
      "processes": [
        {
          "name": "critical-fail",
          "argv": ["/bin/sh", "-c", "exit 7"],
          "critical": true
        },
        {
          "name": "worker",
          "argv": ["/bin/sh", "-c", "sleep 10"]
        }
      ]
    }
  ]
}
